# --- Required ---
# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- Gateway: Telegram (required only for `npm run dev:telegram`) ---
# Create a bot with @BotFather on Telegram, paste the token here.
TELEGRAM_BOT_TOKEN=

# Optional allow-list. Comma-separated — accepts numeric user IDs AND @usernames.
# Leave blank to allow anyone. Get a numeric ID from @userinfobot.
# Note: @username only matches once that person has messaged the bot at least once
#   (Telegram bots can't resolve a handle to an ID until then). Numeric IDs are most robust.
# Example (locks the bot to you + Advait):  TELEGRAM_ALLOWED_USER_IDS=@advait_jayant,123456789
TELEGRAM_ALLOWED_USER_IDS=

# --- Source: Slack (for `npm run learn:slack`) ---
# A Slack USER token (starts with xoxp-), not a bot token. See docs/slack-setup.md
# for the 2-minute app setup + the exact read scopes.
SLACK_USER_TOKEN=

# --- Character ---
# Which character directory under ./characters to load.
CHARACTER=wes

# Model + effort (defaults are sensible; override only if you know why).
WES_MODEL=claude-opus-4-8
WES_EFFORT=high

# --- Optional private personalization ---
# Path to a markdown file describing YOU (voice, context, who you write to).
# Injected into the system prompt so rewrites sound like you. Gitignored.
# e.g. WES_PROFILE_PATH=./personal/profile.md
WES_PROFILE_PATH=
